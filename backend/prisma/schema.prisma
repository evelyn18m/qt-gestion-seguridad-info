// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Amenaza {
  id          Int      @id @default(autoincrement())
  categoria   String
  nombre      String   @db.Text
  tipoFuente  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vulnerabilidad {
  id          Int      @id @default(autoincrement())
  categoria   String
  descripcion String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Impacto {
  id          Int      @id @default(autoincrement())
  tipo        String   // Confidencialidad, Integridad, Disponibilidad
  nivel       String   // Alto, Medio, Bajo
  valor       Int
  criterio    String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Formato {
  id          Int      @id @default(autoincrement())
  nombre      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Subproceso {
  id              Int          @id @default(autoincrement())
  nombre          String       @db.Text
  macroProcesoId  Int
  macroProceso    MacroProceso @relation(fields: [macroProcesoId], references: [id], onDelete: Restrict)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model MacroProceso {
  id           Int          @id @default(autoincrement())
  nombre       String       @db.Text
  codigo       String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  subprocesses Subproceso[]
}

model TipoActivo {
  id          Int      @id @default(autoincrement())
  nombre      String
  detalle     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Valoracion {
  id          Int      @id @default(autoincrement())
  nombre      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Funcionario {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Area {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ValoracionActivo {
  id               Int      @id @default(autoincrement())
  nombreActivo     String   @db.Text
  tipoActivoId     Int
  formatoId        Int
  macroProcesoId   Int
  subProcesoId     Int
  propietarioId    Int
  custodioId       Int
  descripcion      String   @db.Text
  controlSeguridad String   @db.Text
  ubicacion        String   @db.Text
  observaciones    String?  @db.Text
  confidencialidadId Int
  integridadId       Int
  disponibilidadId   Int
  tieneDatosPersonales Boolean @default(false)

  // Análisis de Riesgos (pestañas 2-4)
  amenazas              String?   @db.Text // JSON array of ids
  vulnerabilidades      String?   @db.Text // JSON array of ids
  controlesImplementacion String? @db.Text
  impacto               Float?
  probabilidadId        Int?
  amenazaRiesgoId       Int?
  vulnerabilidadRiesgoId Int?
  controlesArea         String?   @db.Text
  evaluacionRiesgo      Float?
  nivelRiesgo           String?

  // Tratamiento de Riesgo
  metodoTratamiento     String?  @db.Text
  tipoControl           Int?
  controlesImplementar  String?  @db.Text
  nivelAmenazaControl   Int?
  nivelVulnerabilidadControl Int?
  evaluacionRiesgoControl Float?
  nivelRiesgoControl    String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DetalleRiesgo {
  id                    Int      @id @default(autoincrement())
  valoracionActivoId    Int
  tipo                  String   // "amenaza" | "vulnerabilidad"
  catalogoId            Int      // id de Amenaza o Vulnerabilidad
  riesgoId              Int?     // id del catálogo Riesgo seleccionado
  vulnerabilidadRiesgoId Int?    // id del catálogo Riesgo para vulnerabilidad (per-row)
  evaluacionRiesgo      Float?
  nivelRiesgo           String?
  metodoTratamiento     String?  @db.Text
  tipoControlId         Int?
  riesgoControlId       Int?     // id del catálogo Riesgo para control
  evaluacionRiesgoControl Float?
  nivelRiesgoControl    String?
  // Tab 2 new fields (row-based per-row model)
  amenazaIds            String?   @db.Text  // JSON array, e.g. "[3,7]"
  vulnerabilidadIds      String?   @db.Text  // JSON array, e.g. "[5]"
  controlesImplementados String?  @db.Text  // per-row controls
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model TipoControl {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Probabilidad {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Riesgo {
  id          Int      @id @default(autoincrement())
  evaluacion  String   @db.Text
  valor       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


