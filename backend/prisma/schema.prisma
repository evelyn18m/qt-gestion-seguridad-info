// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Amenaza {
  id         Int      @id @default(autoincrement())
  categoria  String
  nombre     String   @db.Text
  tipoFuente String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Vulnerabilidad {
  id          Int      @id @default(autoincrement())
  categoria   String
  descripcion String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Impacto {
  id        Int      @id @default(autoincrement())
  tipo      String // Confidencialidad, Integridad, Disponibilidad
  nivel     String // Alto, Medio, Bajo
  valor     Int
  criterio  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Formato {
  id        Int      @id @default(autoincrement())
  nombre    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subproceso {
  id             Int          @id @default(autoincrement())
  nombre         String       @db.Text
  macroProcesoId Int
  macroProceso   MacroProceso @relation(fields: [macroProcesoId], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model MacroProceso {
  id           Int          @id @default(autoincrement())
  nombre       String       @db.Text
  codigo       String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  subprocesses Subproceso[]
}

model TipoActivo {
  id        Int      @id @default(autoincrement())
  nombre    String
  detalle   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Valoracion {
  id        Int      @id @default(autoincrement())
  nombre    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Funcionario {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Area {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ValoracionActivo {
  id                   Int     @id @default(autoincrement())
  nombreActivo         String  @db.Text
  tipoActivoId         Int
  formatoId            Int
  macroProcesoId       Int
  subProcesoId         Int
  propietarioId        Int
  custodioId           Int
  descripcion          String  @db.Text
  controlSeguridad     String  @db.Text
  ubicacion            String  @db.Text
  observaciones        String? @db.Text
  confidencialidadId   Int
  integridadId         Int
  disponibilidadId     Int
  tieneDatosPersonales Boolean @default(false)

  // Análisis de Riesgos (pestañas 2-4)
  amenazas                String? @db.Text // JSON array of ids
  vulnerabilidades        String? @db.Text // JSON array of ids
  controlesImplementacion String? @db.Text
  impacto                 Float?
  probabilidadId          Int?
  amenazaRiesgoId         Int?
  vulnerabilidadRiesgoId  Int?
  controlesArea           String? @db.Text
  evaluacionRiesgo        Float?
  nivelRiesgo             String?

  // Tratamiento de Riesgo
  metodoTratamiento          String? @db.Text
  tipoControl                Int?
  controlesImplementar       String? @db.Text
  nivelAmenazaControl        Int?
  nivelVulnerabilidadControl Int?
  evaluacionRiesgoControl    Float?
  nivelRiesgoControl         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DetalleRiesgo {
  id                      Int      @id @default(autoincrement())
  valoracionActivoId      Int
  tipo                    String // "amenaza" | "vulnerabilidad"
  catalogoId              Int // id de Amenaza o Vulnerabilidad
  riesgoId                Int? // id del catálogo Riesgo seleccionado
  vulnerabilidadRiesgoId  Int? // id del catálogo Riesgo para vulnerabilidad (per-row)
  evaluacionRiesgo        Float?
  nivelRiesgo             String?
  metodoTratamiento       String?  @db.Text
  tipoControlId           Int
  riesgoControlId         Int? // id del catálogo Riesgo para control
  vulnerabilidadControlId Int? // id del catálogo Riesgo para vulnerabilidad en control
  evaluacionRiesgoControl Float?
  nivelRiesgoControl      String?
  riesgoResidual          String?
  // Tab 2 new fields (row-based per-row model)
  amenazaIds              String?  @db.Text // JSON array, e.g. "[3,7]"
  vulnerabilidadIds       String?  @db.Text // JSON array, e.g. "[5]"
  controlesImplementados  String?  @db.Text // per-row controls (Tab 2 free-text — keep for backward compat)
  controlesArea           String?  @db.Text // per-row controls area (Tab 3 only)
  // Tab 4 FK: selected catalog control to implement
  controlesImplementarId  Int?
  controlesImplementar    ControlesImplementar? @relation(fields: [controlesImplementarId], references: [id])
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model TipoControl {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Probabilidad {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.Text
  valor     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Riesgo {
  id        Int      @id @default(autoincrement())
  tipo      String // Amenaza, Vulnerabilidad
  nivel     String // Alto, Medio, Bajo
  valor     Int // 3=Alto, 2=Medio, 1=Bajo
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategoriaControlesImplementar {
  id                   Int                    @id @default(autoincrement())
  nombre               String
  controlesImplementar ControlesImplementar[]
}

model ConfiguracionRiesgo {
  id                   Int      @id @default(autoincrement())
  riesgoBajoMax        Int      @default(3)
  riesgoBajoDesde      Int      @default(1)
  riesgoMedioMax       Int      @default(9)
  riesgoMedioDesde     Int      @default(3)
  riesgoAltoMax        Int      @default(27)
  riesgoAltoDesde      Int      @default(9)
  controlBajoMax       Int      @default(3)
  controlBajoDesde     Int      @default(1)
  controlMedioMax      Int      @default(9)
  controlMedioDesde    Int      @default(3)
  controlAltoMax       Int      @default(27)
  controlAltoDesde     Int      @default(9)
  residualAceptableMax Int      @default(3)
  residualAceptableDesde   Int @default(1)
  residualInaceptableDesde Int @default(3)
  residualInaceptableMax   Int @default(27)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ControlesImplementar {
  id             Int                           @id @default(autoincrement())
  seccion        String                        @unique
  descripcion    String
  categoriaId    Int
  categoria      CategoriaControlesImplementar @relation(fields: [categoriaId], references: [id])
  detallesRiesgo DetalleRiesgo[]
}
